POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=seleccionador_nombres
POSTGRES_USER=seleccionador
POSTGRES_PASSWORD=seleccionador

# OpenRouter (etiquetado LLM del pilot). Copiá a .env y completá:
# OR_KEY=sk-or-v1-...
# OR_BASE_URL=https://openrouter.ai/api/v1
# OR_HTTP_REFERER=https://github.com/tu-usuario/seleccionador-nombres
# OR_APP_TITLE=seleccionador-nombres

# Web app comparador (local). En Render: DATABASE_URL la inyecta Render al vincular PostgreSQL.
# DATABASE_URL=postgresql://seleccionador:seleccionador@localhost:5432/seleccionador_nombres
